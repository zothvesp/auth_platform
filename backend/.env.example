# ─── AuthForge Backend Environment ──────────────────────────────────────────
# Copy this to .env and fill in your values.
# Secrets must NEVER be committed to version control.

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (docker-compose up -d):
DATABASE_URL=postgres://authforge:authforge_dev@localhost:5432/authforge

# Production example:
# DATABASE_URL=postgres://user:password@prod-host:5432/authforge?sslmode=require

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── JWT (RS256) ─────────────────────────────────────────────────────────────
# Point to PEM files — never paste key content into .env.
# Run `make keys` to generate them, or generate manually:
#   mkdir -p keys
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Token expiry (overrides system_config table defaults)
# JWT_ACCESS_EXPIRY_SECS=900      # 15 minutes
# JWT_REFRESH_EXPIRY_SECS=604800  # 7 days

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false  # Set to true in production (requires HTTPS)

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── App URL (used in emails) ─────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Local dev: use Mailhog (docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@authforge.dev

# ─── OAuth Providers ─────────────────────────────────────────────────────────
# Set these AND enable the provider in system_config via the admin UI or DB:
#   UPDATE system_config SET value='true' WHERE key='oauth.google_enabled';

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# OAuth redirect base (must match provider app settings)
OAUTH_REDIRECT_BASE=http://localhost:5173/auth/callback

# ─── Security (overrides system_config table defaults) ───────────────────────
# MAX_LOGIN_ATTEMPTS=5
# LOCKOUT_DURATION_SECS=900
